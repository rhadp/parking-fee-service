{
  "Vehicle": {
    "type": "branch",
    "description": "High-level vehicle data.",
    "children": {
      "Cabin": {
        "type": "branch",
        "description": "Cabin-related signals.",
        "children": {
          "Door": {
            "type": "branch",
            "description": "Door signals.",
            "children": {
              "Row1": {
                "type": "branch",
                "description": "First row doors.",
                "children": {
                  "DriverSide": {
                    "type": "branch",
                    "description": "Driver-side door.",
                    "children": {
                      "IsLocked": {
                        "type": "sensor",
                        "datatype": "boolean",
                        "description": "Whether the driver-side door is locked"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "CurrentLocation": {
        "type": "branch",
        "description": "Current vehicle location.",
        "children": {
          "Latitude": {
            "type": "sensor",
            "datatype": "double",
            "description": "Current latitude"
          },
          "Longitude": {
            "type": "sensor",
            "datatype": "double",
            "description": "Current longitude"
          }
        }
      },
      "Parking": {
        "type": "branch",
        "description": "Parking-related signals.",
        "children": {
          "SessionActive": {
            "type": "sensor",
            "datatype": "boolean",
            "description": "Whether a parking session is currently active"
          }
        }
      },
      "Command": {
        "type": "branch",
        "description": "Commands sent to vehicle subsystems.",
        "children": {
          "Door": {
            "type": "branch",
            "description": "Door command signals.",
            "children": {
              "Lock": {
                "type": "actuator",
                "datatype": "string",
                "description": "JSON-encoded lock/unlock command request"
              },
              "Response": {
                "type": "sensor",
                "datatype": "string",
                "description": "JSON-encoded command execution result"
              }
            }
          }
        }
      }
    }
  }
}
