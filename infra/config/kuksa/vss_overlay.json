{
    "Vehicle": {
        "type": "branch",
        "description": "Vehicle",
        "children": {
            "Speed": {
                "type": "sensor",
                "datatype": "float",
                "unit": "km/h",
                "description": "Vehicle speed."
            },
            "CurrentLocation": {
                "type": "branch",
                "description": "Current location of the vehicle.",
                "children": {
                    "Latitude": {
                        "type": "sensor",
                        "datatype": "double",
                        "unit": "degrees",
                        "description": "Current latitude."
                    },
                    "Longitude": {
                        "type": "sensor",
                        "datatype": "double",
                        "unit": "degrees",
                        "description": "Current longitude."
                    }
                }
            },
            "Cabin": {
                "type": "branch",
                "description": "Vehicle cabin.",
                "children": {
                    "Door": {
                        "type": "branch",
                        "description": "Door signals.",
                        "children": {
                            "Row1": {
                                "type": "branch",
                                "description": "First row doors.",
                                "children": {
                                    "DriverSide": {
                                        "type": "branch",
                                        "description": "Driver-side door.",
                                        "children": {
                                            "IsLocked": {
                                                "type": "actuator",
                                                "datatype": "boolean",
                                                "description": "Whether the driver-side door is locked."
                                            },
                                            "IsOpen": {
                                                "type": "sensor",
                                                "datatype": "boolean",
                                                "description": "Whether the driver-side door is open."
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "Command": {
                "type": "branch",
                "description": "Vehicle command signals for the SDV Parking Demo.",
                "children": {
                    "Door": {
                        "type": "branch",
                        "description": "Door command signals.",
                        "children": {
                            "Lock": {
                                "type": "actuator",
                                "datatype": "boolean",
                                "description": "Lock/unlock command request. true=lock, false=unlock."
                            },
                            "LockResult": {
                                "type": "sensor",
                                "datatype": "string",
                                "description": "Result of the last lock command processed by LOCKING_SERVICE.",
                                "allowed": ["SUCCESS", "REJECTED_SPEED", "REJECTED_DOOR_OPEN"]
                            }
                        }
                    }
                }
            },
            "Parking": {
                "type": "branch",
                "description": "Parking-related signals for the SDV Parking Demo.",
                "children": {
                    "SessionActive": {
                        "type": "sensor",
                        "datatype": "boolean",
                        "description": "Whether a parking session is currently active. Managed by PARKING_OPERATOR_ADAPTOR."
                    }
                }
            }
        }
    }
}
