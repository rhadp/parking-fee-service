# containers/rhivos/Containerfile.parking-operator-adaptor
#
# Base Image Rationale: Using ubi10/ubi-minimal for balance between size and
# package availability. The parking-operator-adaptor is a dynamic adapter that
# runs in the QM partition and handles parking session management. UBI-minimal
# provides the necessary glibc runtime while keeping the image size optimized
# for on-demand download scenarios where smaller images reduce deployment time.
#
# Build Stage: Using ghcr.io/rhadp/builder per project standards for Rust builds
# (Requirement 8.6).

# Build stage - MUST use ghcr.io/rhadp/builder for Rust builds
FROM ghcr.io/rhadp/builder AS builder

WORKDIR /build

# Copy workspace configuration first for better layer caching
COPY rhivos/Cargo.toml rhivos/Cargo.lock* ./

# Copy all workspace members
COPY rhivos/shared/ shared/
COPY rhivos/locking-service/ locking-service/
COPY rhivos/cloud-gateway-client/ cloud-gateway-client/
COPY rhivos/parking-operator-adaptor/ parking-operator-adaptor/
COPY rhivos/update-service/ update-service/

# Copy proto definitions for build
COPY proto/ /proto/

# Build the parking-operator-adaptor binary in release mode
RUN cargo build --release --package parking-operator-adaptor

# Final stage - MUST use UBI10
FROM registry.access.redhat.com/ubi10/ubi-minimal

LABEL maintainer="SDV Team"
LABEL version="${GIT_VERSION}"
LABEL description="Dynamic Parking Operator Adapter for RHIVOS QM Partition"
LABEL component="parking-operator-adaptor"
LABEL partition="qm"

# Install minimal runtime dependencies
RUN microdnf install -y shadow-utils && microdnf clean all

# Create non-root user for security
RUN useradd -r -u 1000 -g root parking-operator-adaptor

# Copy the compiled binary from builder stage
COPY --from=builder /build/target/release/parking-operator-adaptor /usr/local/bin/

# Run as non-root user
USER parking-operator-adaptor

ENTRYPOINT ["/usr/local/bin/parking-operator-adaptor"]
