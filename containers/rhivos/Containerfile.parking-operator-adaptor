# Containerfile for RHIVOS Parking Operator Adaptor
# Dynamic parking operator adapter for RHIVOS QM partition
#
# Build: podman build -f Containerfile.parking-operator-adaptor -t parking-operator-adaptor:latest ../../rhivos
# Run: podman run --rm parking-operator-adaptor:latest

# =============================================================================
# Stage 1: Builder
# =============================================================================
FROM docker.io/library/rust:1.75-bookworm AS builder

# Install build dependencies
RUN apt-get update && apt-get install -y \
    protobuf-compiler \
    libprotobuf-dev \
    && rm -rf /var/lib/apt/lists/*

# Create a new directory for the build
WORKDIR /build

# Copy the workspace files
COPY Cargo.toml Cargo.lock ./
COPY shared/ ./shared/
COPY locking-service/ ./locking-service/
COPY cloud-gateway-client/ ./cloud-gateway-client/
COPY parking-operator-adaptor/ ./parking-operator-adaptor/
COPY update-service/ ./update-service/

# Build the parking-operator-adaptor binary in release mode
RUN cargo build --release --package parking-operator-adaptor

# =============================================================================
# Stage 2: Runtime
# =============================================================================
FROM docker.io/library/debian:bookworm-slim AS runtime

# Install runtime dependencies
RUN apt-get update && apt-get install -y \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user for security
RUN useradd --create-home --user-group --uid 1000 rhivos

# Copy the binary from builder stage
COPY --from=builder /build/target/release/parking-operator-adaptor /usr/local/bin/parking-operator-adaptor

# Set ownership and permissions
RUN chown rhivos:rhivos /usr/local/bin/parking-operator-adaptor && \
    chmod 755 /usr/local/bin/parking-operator-adaptor

# Create directories for runtime data
RUN mkdir -p /run/rhivos && chown rhivos:rhivos /run/rhivos

# Switch to non-root user
USER rhivos

# Set working directory
WORKDIR /home/rhivos

# OCI-compliant labels
LABEL org.opencontainers.image.title="RHIVOS Parking Operator Adaptor" \
      org.opencontainers.image.description="Dynamic parking operator adapter for RHIVOS QM partition" \
      org.opencontainers.image.vendor="SDV Parking Demo Team" \
      org.opencontainers.image.licenses="Apache-2.0" \
      org.opencontainers.image.source="https://github.com/example/parking-fee-service" \
      org.opencontainers.image.documentation="https://github.com/example/parking-fee-service/blob/main/rhivos/parking-operator-adaptor/README.md"

# Expose gRPC port
EXPOSE 50052

# Health check
HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
    CMD ["/usr/local/bin/parking-operator-adaptor", "--health-check"] || exit 1

# Set entrypoint
ENTRYPOINT ["/usr/local/bin/parking-operator-adaptor"]
