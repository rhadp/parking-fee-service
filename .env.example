# Backend: parking-fee-service
CONFIG_PATH=

# Backend: cloud-gateway
HTTP_PORT=8081
NATS_URL=nats://localhost:4222
KNOWN_VINS=VIN12345,VIN67890

# Rhivos: cloud-gateway-client
VIN=TEST-VIN-001
NATS_TLS_ENABLED=false
DATABROKER_UDS_PATH=/tmp/kuksa/databroker.sock

# Rhivos: locking-service (also uses DATABROKER_UDS_PATH above)
DATABROKER_ADDR=http://localhost:55556

# Rhivos: parking-operator-adaptor
PARKING_OPERATOR_URL=http://localhost:9090
DATA_BROKER_ADDR=http://localhost:55556
GRPC_PORT=50052
VEHICLE_ID=DEMO-VIN-001
ZONE_ID=zone-demo-1

# Rhivos: update-service
UPDATE_SERVICE_GRPC_PORT=50060
UPDATE_SERVICE_REGISTRY_BASE_URL=europe-west1-docker.pkg.dev/rhadp-parking-demo/adapters
UPDATE_SERVICE_INACTIVITY_TIMEOUT_SECS=86400
UPDATE_SERVICE_STORAGE_PATH=/var/lib/containers/adapters/

# Mock: parking-operator
PORT=9090

# Mock: parking-app-cli
PARKING_FEE_SERVICE_URL=http://localhost:8080
UPDATE_SERVICE_ADDR=localhost:50051
PARKING_ADAPTOR_ADDR=localhost:50052

# Mock: companion-app-cli
CLOUD_GATEWAY_URL=http://localhost:8081
BEARER_TOKEN=your-bearer-token-here

# Logging
RUST_LOG=info
