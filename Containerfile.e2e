# Minimal runtime image for E2E testing.
#
# Expects a pre-built Linux binary in build/.
#
# Build args:
#   BINARY — filename of the binary in build/ (e.g. update-service)
#
# Usage (via Makefile — not called directly):
#   podman build -f Containerfile.e2e --build-arg BINARY=update-service -t parking-e2e/update-service .

FROM registry.access.redhat.com/ubi10/ubi-minimal:latest

ARG BINARY

COPY build/${BINARY} /usr/local/bin/app

USER 1001

ENTRYPOINT ["app"]
